# Copy this file to ".env" and fill in your key. The .env file is gitignored.
#   PowerShell:  Copy-Item .env.example .env
#   bash/zsh:    cp .env.example .env
#
# On Replit: don't use a .env file -- add these in the "Secrets" tab instead
# (same variable names). The app reads them identically.

ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for drafting recommendations.
# Defaults to claude-sonnet-4-6 (fast + cheap, good for short drafts).
# COPILOT_MODEL=claude-opus-4-8
